---
// Banner RGPD / LSSI-CE art. 22. Bloquea el Meta Pixel hasta que el usuario decide.
// Estado en localStorage 'vb_consent_v1' = 'accepted' | 'rejected'.
// Tres acciones al MISMO nivel visual (AEPD 2026): Rechazar / Configurar / Aceptar.
const PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID || '';
---
<aside id="cookie-banner" class="cookie-banner" hidden>
  <div class="cookie-inner">
    <div class="cookie-text">
      <strong>Privacidad y cookies.</strong>
      Usamos cookies propias técnicas (necesarias para que la web funcione) y de terceros (Meta) para
      medir el rendimiento. Puedes aceptarlas, rechazarlas o configurarlas. Más información en la
      <a href="/cookies">política de cookies</a>.
    </div>

    <div id="cookie-prefs" class="cookie-prefs" hidden>
      <label class="cookie-pref">
        <span><strong>Cookies técnicas</strong><small>Imprescindibles para el funcionamiento. Siempre activas.</small></span>
        <input type="checkbox" checked disabled aria-label="Cookies técnicas (siempre activas)" />
      </label>
      <label class="cookie-pref">
        <span><strong>Cookies de medición y publicidad (Meta)</strong><small>Atribución de campañas. Desactivadas por defecto.</small></span>
        <input type="checkbox" id="cookie-analytics" />
      </label>
    </div>

    <div class="cookie-actions">
      <button type="button" id="cookie-reject" class="cookie-btn cookie-btn-reject">Rechazar todas</button>
      <button type="button" id="cookie-config" class="cookie-btn cookie-btn-config">Configurar</button>
      <button type="button" id="cookie-save" class="cookie-btn cookie-btn-accept" hidden>Guardar preferencias</button>
      <button type="button" id="cookie-accept" class="cookie-btn cookie-btn-accept">Aceptar todas</button>
    </div>
  </div>
</aside>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 12px;
    left: 12px;
    right: 12px;
    z-index: 60;
    background: rgba(13,15,17,0.97);
    border: 1px solid rgba(46,55,64,0.6);
    border-radius: var(--radius-md);
    padding: 16px 18px;
    box-shadow: var(--shadow-deep);
    color: var(--anthracite-100);
    font-size: 13px;
    line-height: 1.55;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding-bottom: max(16px, env(safe-area-inset-bottom));
  }
  .cookie-inner { display: flex; flex-direction: column; gap: 14px; }
  .cookie-text strong { color: #fff; }
  .cookie-text a { color: var(--brand-orange-400); }

  .cookie-prefs {
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 12px;
  }
  .cookie-prefs[hidden] { display: none; }
  .cookie-pref { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .cookie-pref span { display: flex; flex-direction: column; gap: 2px; }
  .cookie-pref strong { color: #fff; font-size: 13px; }
  .cookie-pref small { color: var(--anthracite-200); font-size: 11.5px; line-height: 1.4; }
  .cookie-pref input { width: 18px; height: 18px; accent-color: var(--brand-orange-500); flex-shrink: 0; }

  /* Acciones: las tres al mismo tamaño. Aceptar y Rechazar con igual prominencia (AEPD). */
  .cookie-actions { display: flex; flex-direction: column; gap: 8px; }
  .cookie-btn {
    padding: 11px 16px;
    min-height: 44px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid transparent;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    touch-action: manipulation;
  }
  .cookie-btn-accept { background: var(--brand-orange-500); color: #fff; }
  .cookie-btn-accept:hover { background: var(--brand-orange-400); }
  .cookie-btn-reject { background: var(--anthracite-700); color: #fff; border-color: rgba(255,255,255,0.16); }
  .cookie-btn-reject:hover { background: var(--anthracite-600); }
  .cookie-btn-config { background: transparent; color: var(--anthracite-100); border-color: rgba(74,85,98,0.7); }
  .cookie-btn-config:hover { border-color: var(--brand-orange-400); color: var(--brand-orange-400); }

  @media (min-width: 768px) {
    .cookie-banner { max-width: 760px; left: auto; right: 24px; }
    .cookie-actions { flex-direction: row; justify-content: flex-end; }
    .cookie-btn { min-width: 150px; }
  }
</style>

<script is:inline define:vars={{ PIXEL_ID }}>
  (function () {
    const KEY = 'vb_consent_v1';
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    const rejectBtn = document.getElementById('cookie-reject');
    const configBtn = document.getElementById('cookie-config');
    const saveBtn = document.getElementById('cookie-save');
    const prefs = document.getElementById('cookie-prefs');
    const analyticsToggle = document.getElementById('cookie-analytics');
    if (!banner || !acceptBtn || !rejectBtn) return;

    function loadPixel() {
      if (!PIXEL_ID || window.fbq) return;
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
        if (!f._fbq) f._fbq = n;
        n.push = n; n.loaded = !0; n.version = '2.0'; n.queue = [];
        t = b.createElement(e); t.async = !0; t.src = v;
        s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
      })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
      window.fbq('init', PIXEL_ID);
      window.fbq('track', 'PageView');
    }

    function decide(decision) {
      try { localStorage.setItem(KEY, decision); } catch (e) {}
      banner.hidden = true;
      if (decision === 'accepted') loadPixel();
    }

    const stored = localStorage.getItem(KEY);
    if (stored === 'accepted') { loadPixel(); return; }
    if (stored === 'rejected') return;
    banner.hidden = false;

    acceptBtn.addEventListener('click', () => decide('accepted'));
    rejectBtn.addEventListener('click', () => decide('rejected'));

    if (configBtn && prefs && saveBtn) {
      configBtn.addEventListener('click', () => {
        prefs.hidden = false;
        configBtn.hidden = true;
        saveBtn.hidden = false;
      });
      saveBtn.addEventListener('click', () => {
        decide(analyticsToggle && analyticsToggle.checked ? 'accepted' : 'rejected');
      });
    }
  })();
</script>
