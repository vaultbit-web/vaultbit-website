---
import JsonLd from './JsonLd.astro';
import { SITE_URL } from '~/data/organization';

interface Crumb { label: string; href: string; }
interface Props { items: Crumb[]; }

const { items } = Astro.props;

const schema = {
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    item: new URL(c.href, SITE_URL).toString(),
  })),
};
---
<nav class="breadcrumbs" aria-label="Migas de pan">
  <ol>
    {items.map((c, i) => (
      <li>
        {i < items.length - 1 ? (
          <a href={c.href}>{c.label}</a>
        ) : (
          <span aria-current="page">{c.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
<JsonLd data={schema} />

<style>
  .breadcrumbs {
    padding: 16px 0;
    font-size: 13px;
  }
  .breadcrumbs ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .breadcrumbs li + li::before {
    content: '/';
    color: var(--anthracite-400);
    margin-right: 6px;
  }
  .breadcrumbs a {
    color: var(--anthracite-200);
    text-decoration: none;
  }
  .breadcrumbs a:hover { color: var(--brand-orange-400); }
  .breadcrumbs span[aria-current='page'] {
    color: var(--anthracite-100);
  }
</style>
