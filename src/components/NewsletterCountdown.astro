---
interface Props {
  dropDate: Date;
  title: string;
  excerpt: string;
  heroImage: string;
  heroAlt: string;
  issueNumber: number;
  subscribeUrl?: string;
}

const {
  dropDate,
  title,
  excerpt,
  heroImage,
  heroAlt,
  issueNumber,
  subscribeUrl = '/#newsletter',
} = Astro.props;

const dropIso = dropDate.toISOString();
const fmtLong = dropDate.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  timeZone: 'Europe/Madrid',
});
const fmtTime = dropDate.toLocaleTimeString('es-ES', {
  hour: '2-digit',
  minute: '2-digit',
  timeZone: 'Europe/Madrid',
  hour12: false,
});
const eyebrow = `Newsletter #${String(issueNumber).padStart(3, '0')} · ${fmtLong} · ${fmtTime} h`;

const initial = Math.max(0, dropDate.getTime() - Date.now());
const initialDays = Math.floor(initial / 86400000);
const initialHours = Math.floor((initial % 86400000) / 3600000);
const initialMinutes = Math.floor((initial % 3600000) / 60000);
const initialSeconds = Math.floor((initial % 60000) / 1000);
const pad = (n: number) => String(n).padStart(2, '0');
---
<section class="countdown-wrap">
  <header class="countdown-header container">
    <p class="countdown-eyebrow">{eyebrow}</p>
    <h1 class="countdown-title">{title}</h1>
    <p class="countdown-lead">{excerpt}</p>
  </header>

  <figure class="countdown-hero">
    <img
      src={heroImage}
      alt={heroAlt}
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </figure>

  <div class="countdown-body container">
    <div
      class="countdown-card"
      data-drop-date={dropIso}
      role="timer"
      aria-live="polite"
      aria-label={`Cuenta atrás hasta el ${fmtLong} a las ${fmtTime}`}
    >
      <div class="countdown-block">
        <span class="countdown-number" data-unit="days">{pad(initialDays)}</span>
        <span class="countdown-label">Días</span>
      </div>
      <span class="countdown-separator" aria-hidden="true">·</span>
      <div class="countdown-block">
        <span class="countdown-number" data-unit="hours">{pad(initialHours)}</span>
        <span class="countdown-label">Horas</span>
      </div>
      <span class="countdown-separator" aria-hidden="true">·</span>
      <div class="countdown-block">
        <span class="countdown-number" data-unit="minutes">{pad(initialMinutes)}</span>
        <span class="countdown-label">Minutos</span>
      </div>
      <span class="countdown-separator" aria-hidden="true">·</span>
      <div class="countdown-block">
        <span class="countdown-number" data-unit="seconds">{pad(initialSeconds)}</span>
        <span class="countdown-label">Segundos</span>
      </div>
    </div>

    <aside class="countdown-cta">
      <p class="countdown-cta-eyebrow">¿No quiere perdérsela?</p>
      <p class="countdown-cta-desc">
        Reciba la newsletter directamente en su correo y le llegará el día del drop sin que tenga que volver aquí.
      </p>
      <a class="btn btn-primary" href={subscribeUrl}>Suscribirse a la newsletter</a>
    </aside>

    <nav class="countdown-back">
      <a href="/newsletter">← Volver al newsletter</a>
    </nav>
  </div>
</section>

<script is:inline>
  (function () {
    const card = document.querySelector('.countdown-card');
    if (!card) return;
    const dropIso = card.getAttribute('data-drop-date');
    if (!dropIso) return;
    const dropTs = new Date(dropIso).getTime();
    const elDays = card.querySelector('[data-unit="days"]');
    const elHours = card.querySelector('[data-unit="hours"]');
    const elMinutes = card.querySelector('[data-unit="minutes"]');
    const elSeconds = card.querySelector('[data-unit="seconds"]');
    const pad = function (n) { return String(n).padStart(2, '0'); };

    let timer = null;
    let done = false;
    function revealOnce() {
      // Recarga UNA sola vez por sesion para mostrar el articulo ya publicado.
      // Si el build todavia no se ha actualizado, NO vuelve a recargar: evita el bucle.
      try {
        const key = 'vb-drop-reloaded:' + dropIso;
        if (!sessionStorage.getItem(key)) {
          sessionStorage.setItem(key, '1');
          window.location.reload();
        }
      } catch (e) { /* sessionStorage no disponible: no recargar */ }
    }
    function tick() {
      const diff = dropTs - Date.now();
      if (diff <= 0) {
        elDays.textContent = '00';
        elHours.textContent = '00';
        elMinutes.textContent = '00';
        elSeconds.textContent = '00';
        if (!done) {
          done = true;
          if (timer) clearInterval(timer);
          revealOnce();
        }
        return;
      }
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      elDays.textContent = pad(d);
      elHours.textContent = pad(h);
      elMinutes.textContent = pad(m);
      elSeconds.textContent = pad(s);
    }

    tick();
    if (!done) timer = setInterval(tick, 1000);
  })();
</script>

<style>
  .countdown-wrap {
    background: var(--surface-light);
    color: var(--anthracite-400);
    padding-bottom: 64px;
  }
  @media (min-width: 768px) { .countdown-wrap { padding-bottom: 96px; } }

  .countdown-header {
    text-align: center;
    padding-top: 48px;
    padding-bottom: 28px;
    max-width: 820px;
  }
  @media (min-width: 768px) {
    .countdown-header { padding-top: 64px; padding-bottom: 40px; }
  }
  .countdown-eyebrow {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brand-orange-500);
    margin: 0 0 16px;
    font-weight: 600;
  }
  .countdown-title {
    font-size: clamp(28px, 4.5vw, 44px);
    line-height: 1.15;
    letter-spacing: -1px;
    color: var(--anthracite-950);
    margin: 0 0 16px;
    font-weight: 700;
  }
  .countdown-lead {
    font-size: 18px;
    line-height: 1.6;
    color: var(--anthracite-400);
    margin: 0 auto;
    max-width: 60ch;
  }

  .countdown-hero {
    margin: 0 auto 40px;
    max-width: 1180px;
    padding: 0 var(--container-px);
  }
  @media (min-width: 1024px) { .countdown-hero { padding: 0 var(--container-px-lg); } }
  .countdown-hero img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    display: block;
  }

  .countdown-body { max-width: 820px; }

  .countdown-card {
    background: var(--anthracite-800);
    border: 1px solid rgba(242,118,26,0.20);
    border-radius: 24px;
    padding: 28px 16px;
    margin: 0 0 40px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-shadow: var(--shadow-xl);
  }
  @media (min-width: 640px) {
    .countdown-card { padding: 48px 32px; gap: 12px; }
  }
  .countdown-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 52px;
  }
  @media (min-width: 640px) { .countdown-block { min-width: 80px; } }
  .countdown-number {
    font-weight: 800;
    font-size: clamp(2rem, 9vw, 5rem);
    color: var(--brand-orange-500);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .countdown-label {
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--anthracite-200, #8A95A0);
    margin-top: 8px;
  }
  @media (min-width: 640px) { .countdown-label { font-size: 12px; } }
  .countdown-separator {
    color: rgba(242,118,26,0.40);
    font-size: clamp(1.25rem, 5vw, 4rem);
    font-weight: 800;
    align-self: center;
    line-height: 1;
    user-select: none;
  }

  .countdown-cta {
    background: #fff;
    border: 1px solid rgba(46,55,64,0.10);
    border-left: 3px solid var(--brand-orange-500);
    border-radius: var(--radius-lg);
    padding: 24px 26px;
    margin: 0 0 32px;
    box-shadow: var(--shadow-soft);
  }
  .countdown-cta-eyebrow {
    color: var(--brand-orange-500);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 8px;
    font-weight: 600;
  }
  .countdown-cta-desc {
    font-size: 15px;
    color: var(--anthracite-700, #2E3740);
    line-height: 1.6;
    margin: 0 0 18px;
  }

  .countdown-back {
    margin-top: 24px;
    text-align: center;
    font-size: 14px;
  }
  .countdown-back a {
    color: var(--anthracite-400);
    text-decoration: none;
  }
  .countdown-back a:hover { color: var(--brand-orange-500); }
</style>
