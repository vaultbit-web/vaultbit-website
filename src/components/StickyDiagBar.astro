---
/**
 * StickyDiagBar — barra superior persistente que aparece SOLO si el visitante
 * llega desde el funnel del diagnóstico (URL contiene `?from=diag`).
 * Muestra el estado del informe y mantiene accesibles WhatsApp + Cal.com.
 *
 * Activación: lectura de URL en cliente con un script ligero. Si no hay flag,
 * el contenedor se queda oculto y no ocupa espacio.
 */
import { CONTACT } from '~/data/organization';
const wa = `https://wa.me/${CONTACT.whatsappRaw}`;
const cal = CONTACT.calCom;
---
<div id="sticky-diag-bar" class="sticky-diag-bar" aria-hidden="true" hidden>
  <div class="container sticky-diag-inner">
    <div class="sticky-diag-msg">
      <span class="dot" aria-hidden="true"></span>
      <span><strong>Tu informe está en camino.</strong> Mientras llega, te cuento por qué nació esto.</span>
    </div>
    <div class="sticky-diag-ctas">
      <a class="sticky-diag-btn sticky-diag-btn-wa" href={wa} target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        WhatsApp
      </a>
      <a class="sticky-diag-btn sticky-diag-btn-cal" href={cal} target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        Reservar 30 min
      </a>
    </div>
  </div>
</div>

<style>
  .sticky-diag-bar {
    position: sticky;
    top: 60px;
    z-index: 40;
    background: linear-gradient(to right, rgba(242,118,26,0.95), rgba(212,98,14,0.95));
    color: #fff;
    border-bottom: 1px solid rgba(0,0,0,0.15);
    box-shadow: 0 8px 16px -8px rgba(0,0,0,0.4);
  }
  @media (min-width: 640px) { .sticky-diag-bar { top: 64px; } }
  .sticky-diag-bar[hidden] { display: none; }

  .sticky-diag-inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    padding-top: 12px;
    padding-bottom: 12px;
  }
  @media (min-width: 768px) {
    .sticky-diag-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
  }

  .sticky-diag-msg {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    line-height: 1.4;
  }
  .sticky-diag-msg strong { font-weight: 700; }
  .sticky-diag-msg .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(255,255,255,0.4);
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .sticky-diag-ctas {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .sticky-diag-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    min-height: 40px;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.35);
    border-radius: var(--radius-md);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
    white-space: nowrap;
  }
  .sticky-diag-btn:hover {
    background: rgba(255,255,255,0.28);
    color: #fff;
    transform: translateY(-1px);
  }
</style>

<script is:inline>
  (function () {
    var bar = document.getElementById('sticky-diag-bar');
    if (!bar) return;
    try {
      var qs = new URLSearchParams(window.location.search);
      if (qs.get('from') === 'diag') {
        bar.hidden = false;
        bar.setAttribute('aria-hidden', 'false');
      }
    } catch (e) { /* noop */ }
  })();
</script>
