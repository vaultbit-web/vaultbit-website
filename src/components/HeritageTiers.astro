---
import type { HeritageTier } from '~/data/service-details';
import { calLink } from '~/data/organization';

interface Props {
  tiers: HeritageTier[];
}

const { tiers } = Astro.props;

// Icono limpio (set naranja, trazo oscuro + toque naranja) por nivel. Uno distinto.
const TIER_ICON: Record<string, string> = {
  'foundation': '/assets/icons/naranja/n-08.png',
  'heritage': '/assets/icons/naranja/n-05.png',
  'family-office': '/assets/icons/naranja/n-07.png',
};
---
<section class="section section-light tiers-section">
  <div class="container">
    <div class="text-center mb-8 tiers-intro">
      <span class="eyebrow">Elige tu nivel</span>
      <h2 class="h2-section mt-4">Elige el protocolo que mejor se adapta a ti</h2>
      <p class="body-text-light mt-4 max-w-2xl mx-auto">
        Lo dividimos en tres niveles para que la protección encaje con tu patrimonio, sin pasarte ni quedarte corto. Antes de elegir hacemos un Diagnóstico 360º: su coste se descuenta de la puesta en marcha si sigues adelante en los 30 días siguientes.
      </p>
    </div>

    <div class="tiers-grid">
      {tiers.map((tier) => (
        <article class={`tier-card ${tier.badge ? 'tier-card-featured' : ''}`} data-tier>
          {tier.badge && <span class="tier-badge">{tier.badge}</span>}

          <div class="tier-inner">
            <!-- Cara frontal -->
            <div class="tier-face tier-front">
              {TIER_ICON[tier.id] && (
                <div class="tier-icon"><img src={TIER_ICON[tier.id]} alt="" width="44" height="44" loading="lazy" decoding="async" /></div>
              )}
              <h3 class="tier-name">{tier.name}</h3>
              <p class="tier-patrimony-label">Para patrimonios</p>
              <p class="tier-patrimony">{tier.patrimonyRange}</p>
              <p class="tier-ideal-for">{tier.idealFor}</p>
              <p class="tier-scheme">Reparto de claves: <strong>{tier.shamirScheme}</strong></p>
              <span class="tier-flip-hint" aria-hidden="true">
                <span class="hint-pc">Pasa el ratón para ver qué incluye</span>
                <span class="hint-touch">Toca para ver qué incluye</span>
              </span>
            </div>

            <!-- Cara trasera: qué incluye -->
            <div class="tier-face tier-back">
              <h3 class="tier-back-title">{tier.name} · qué incluye</h3>
              <ul class="tier-includes">
                {tier.includes.map((item) => <li>{item}</li>)}
              </ul>
              <div class="tier-hardware">
                <span class="tier-hardware-label">Placas</span>
                <p class="tier-hardware-text">{tier.hardware.label}</p>
              </div>
            </div>
          </div>

          <button class="tier-flip-btn" type="button" aria-label="Ver qué incluye">
            <span class="flip-show">Ver qué incluye</span>
            <span class="flip-hide">Volver</span>
          </button>

          <a class="btn btn-primary tier-cta" href={calLink('Protocolo de Herencia · nivel ' + tier.name)} target="_blank" rel="noopener">
            Hablar con Daniel
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </article>
      ))}
    </div>

    <div class="tiers-note mt-8">
      <p>Tú generas y guardas tus claves: no las vemos en ningún momento.</p>
      <p>Servicio conjunto con notario y fiscalista colegiados de la red, que firman lo legal.</p>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.tier-flip-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card = btn.closest('[data-tier]');
      card?.classList.toggle('is-flipped');
    });
  });
</script>

<style>
  .tiers-section { padding-top: 56px; padding-bottom: 56px; }
  @media (min-width: 768px) { .tiers-section { padding-top: 80px; padding-bottom: 80px; } }

  .tiers-intro { max-width: 720px; margin-left: auto; margin-right: auto; }

  .tiers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 40px;
  }
  @media (min-width: 900px) {
    .tiers-grid { grid-template-columns: repeat(3, 1fr); align-items: stretch; }
  }

  .tier-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .tier-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    background: var(--brand-orange-500);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  /* ───── Tarjeta con giro ───── */
  .tier-inner {
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0.1, 0.2, 1);
    min-height: 470px;
  }
  @media (min-width: 900px) { .tier-inner { min-height: 500px; } }
  @media (hover: hover) {
    .tier-card:hover .tier-inner { transform: rotateY(180deg); }
  }
  .tier-card.is-flipped .tier-inner { transform: rotateY(180deg); }

  .tier-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    padding: 30px 26px;
    background: #fff;
    border: 1px solid rgba(46,55,64,0.12);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
  }
  .tier-card-featured .tier-face {
    border-color: rgba(242,118,26,0.45);
    box-shadow: 0 0 0 1px rgba(242,118,26,0.15), 0 18px 36px -8px rgba(242,118,26,0.18);
  }
  .tier-back { transform: rotateY(180deg); }

  /* Icono limpio, sin medallón */
  .tier-icon {
    display: flex;
    margin-bottom: 14px;
  }
  .tier-icon img { width: 52px; height: 52px; object-fit: contain; }

  .tier-name {
    font-size: 26px;
    font-weight: 700;
    color: var(--anthracite-950);
    margin: 0 0 12px;
    letter-spacing: -0.4px;
  }
  .tier-patrimony-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-orange-500);
    margin: 0;
  }
  .tier-patrimony {
    font-size: 19px;
    font-weight: 600;
    color: var(--anthracite-950);
    margin: 2px 0 16px;
    letter-spacing: -0.3px;
  }
  .tier-ideal-for {
    font-size: 14px;
    color: var(--anthracite-400);
    line-height: 1.6;
    margin: 0 0 16px;
    flex: 1;
  }
  .tier-scheme {
    font-size: 13px;
    color: var(--anthracite-400);
    margin: 0;
    padding-top: 14px;
    border-top: 1px solid rgba(46,55,64,0.10);
  }
  .tier-scheme strong { color: var(--anthracite-950); }

  .tier-flip-hint {
    margin-top: 12px;
    font-size: 12px;
    color: var(--anthracite-200);
    font-style: italic;
  }
  .hint-touch { display: none; }
  @media (hover: none) {
    .hint-pc { display: none; }
    .hint-touch { display: inline; }
  }

  /* Cara trasera */
  .tier-back-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--brand-orange-500);
    margin: 0 0 14px;
  }
  .tier-includes {
    list-style: none;
    padding: 0;
    margin: 0 0 14px;
    display: flex;
    flex-direction: column;
    gap: 9px;
    flex: 1;
  }
  .tier-includes li {
    font-size: 13.5px;
    color: var(--anthracite-400);
    line-height: 1.5;
    padding-left: 22px;
    position: relative;
  }
  .tier-includes li::before {
    content: '';
    position: absolute;
    left: 0; top: 3px;
    width: 14px; height: 14px;
    background: rgba(22,163,74,0.12);
    border-radius: 50%;
  }
  .tier-includes li::after {
    content: '';
    position: absolute;
    left: 3px; top: 7px;
    width: 8px; height: 4px;
    border-left: 2px solid var(--success);
    border-bottom: 2px solid var(--success);
    transform: rotate(-45deg);
  }
  .tier-hardware {
    padding: 12px 14px;
    background: rgba(46,55,64,0.04);
    border: 1px solid rgba(46,55,64,0.08);
    border-radius: var(--radius-md);
  }
  .tier-hardware-label {
    display: block;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-orange-500);
    margin-bottom: 4px;
  }
  .tier-hardware-text {
    font-size: 12.5px;
    color: var(--anthracite-950);
    margin: 0;
    line-height: 1.5;
  }

  /* Botón de giro (móvil/accesibilidad) + CTA */
  .tier-flip-btn {
    align-self: center;
    font-size: 13px;
    font-weight: 600;
    color: var(--brand-orange-500);
    padding: 6px 10px;
  }
  .flip-hide { display: none; }
  .tier-card.is-flipped .flip-show { display: none; }
  .tier-card.is-flipped .flip-hide { display: inline; }
  @media (hover: hover) { .tier-flip-btn { display: none; } }

  .tier-cta { justify-content: center; }

  .tiers-note {
    max-width: 720px;
    margin: 0 auto;
    padding-top: 28px;
    border-top: 1px solid rgba(46,55,64,0.08);
    text-align: center;
  }
  .tiers-note p {
    font-size: 12.5px;
    color: var(--anthracite-400);
    margin: 0 0 6px;
    line-height: 1.55;
    font-style: italic;
  }
</style>
