---
import BaseLayout from '~/layouts/BaseLayout.astro';
import BreadcrumbBar from '~/components/BreadcrumbBar.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbLabel: string;
  breadcrumbHref: string;
  lastUpdate: string;
  noindex?: boolean;
}
const { title, description, breadcrumbLabel, breadcrumbHref, lastUpdate, noindex = false } = Astro.props;
---
<BaseLayout title={title} description={description} noindex={noindex}>
  <div class="container">
    <BreadcrumbBar items={[
      { label: 'Inicio', href: '/' },
      { label: breadcrumbLabel, href: breadcrumbHref },
    ]} />
  </div>

  <article class="section section-light legal-page">
    <div class="container">
      <header class="legal-header">
        <span class="eyebrow">Información legal</span>
        <h1 class="legal-h1">{title}</h1>
        <p class="legal-meta">Última actualización: {lastUpdate}</p>
      </header>

      <div class="legal-content">
        <slot />
      </div>

      <footer class="legal-footer">
        <p class="legal-footer-text">
          ¿Tienes una duda concreta sobre esta política? Escríbenos a
          <a href="mailto:info@vaultbit.es">info@vaultbit.es</a>.
        </p>
      </footer>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .legal-page {
    color: var(--anthracite-400);
  }
  .legal-header {
    max-width: 820px;
    margin: 0 auto 48px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(46,55,64,0.15);
  }
  .legal-h1 {
    font-size: clamp(32px, 5vw, 44px) !important;
    color: var(--anthracite-950) !important;
    margin: 12px 0 8px !important;
    letter-spacing: -1px;
    font-weight: 700;
  }
  .legal-meta {
    font-size: 13px;
    color: var(--anthracite-400);
    margin: 0;
  }
  .legal-content {
    max-width: 820px;
    margin: 0 auto;
    color: var(--anthracite-400);
    font-size: 15px;
    line-height: 1.75;
  }
  .legal-content h2 {
    font-size: 22px !important;
    color: var(--anthracite-950) !important;
    margin: 40px 0 14px !important;
    font-weight: 600;
    letter-spacing: -0.3px;
  }
  .legal-content h2:first-child { margin-top: 0 !important; }
  .legal-content h3 {
    font-size: 17px !important;
    color: var(--anthracite-950) !important;
    margin: 28px 0 10px !important;
    font-weight: 600;
  }
  .legal-content p {
    margin: 0 0 16px;
    line-height: 1.75;
  }
  .legal-content ul, .legal-content ol {
    margin: 0 0 18px;
    padding-left: 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .legal-content li { line-height: 1.65; }
  .legal-content strong { color: var(--anthracite-950); font-weight: 600; }
  .legal-content a { color: var(--brand-orange-500); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; overflow-wrap: anywhere; }
  .legal-content a:hover { color: var(--brand-orange-600); }

  /* Definition list */
  .legal-content dl {
    margin: 0 0 18px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  @media (min-width: 640px) {
    .legal-content dl { grid-template-columns: 200px 1fr; gap: 4px 24px; }
  }
  .legal-content dt {
    font-weight: 600;
    color: var(--anthracite-950);
    font-size: 14px;
    overflow-wrap: break-word;
  }
  .legal-content dd { margin: 0; }

  /* Tables */
  .legal-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 16px 0 24px;
    font-size: 14px;
    background: #fff;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }
  .legal-content thead th {
    background: var(--surface-light);
    color: var(--anthracite-950);
    font-weight: 600;
    font-size: 13px;
    text-align: left;
    padding: 12px 14px;
    border-bottom: 1px solid rgba(46,55,64,0.12);
  }
  .legal-content tbody td {
    padding: 12px 14px;
    border-bottom: 1px solid rgba(46,55,64,0.08);
    vertical-align: top;
    color: var(--anthracite-400);
  }
  .legal-content tbody tr:last-child td { border-bottom: 0; }
  .legal-content tbody td code {
    background: rgba(46,55,64,0.08);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 12px;
    font-family: ui-monospace, monospace;
    color: var(--anthracite-950);
  }
  /* Móvil: la tabla hace scroll horizontal propio en vez de desbordar/recortar la página */
  @media (max-width: 640px) {
    .legal-content table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  }

  /* Callout box */
  .legal-callout {
    background: rgba(242,118,26,0.06);
    border: 1px solid rgba(242,118,26,0.25);
    border-left: 3px solid var(--brand-orange-500);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    margin: 20px 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--anthracite-400);
  }
  .legal-callout strong { color: var(--brand-orange-500); }

  .legal-footer {
    max-width: 820px;
    margin: 56px auto 0;
    padding-top: 28px;
    border-top: 1px solid rgba(46,55,64,0.15);
    text-align: center;
  }
  .legal-footer-text {
    font-size: 14px;
    color: var(--anthracite-400);
    margin: 0;
  }
  .legal-footer-text a { color: var(--brand-orange-500); }
</style>
