---
import BaseLayout from '~/layouts/BaseLayout.astro';
import BreadcrumbBar from '~/components/BreadcrumbBar.astro';
import PdfMockupCard from '~/components/PdfMockupCard.astro';
---
<BaseLayout
  title="Recursos y guías · VaultBit Advisory"
  description="Guías técnicas gratuitas sobre custodia, herencia y fiscalidad de criptoactivos en España, escritas por Daniel Brosed Giral, fundador de VaultBit Advisory."
>
  <div class="container">
    <BreadcrumbBar items={[
      { label: 'Inicio', href: '/' },
      { label: 'Recursos', href: '/recursos' },
    ]} />
  </div>

  <section class="section section-light">
    <div class="container">
      <div class="text-center mb-8">
        <span class="eyebrow">Recursos</span>
        <h1 class="h2-section mt-4">Guías y contenido técnico</h1>
        <p class="body-text-light mt-4 max-w-2xl mx-auto">
          Material práctico escrito por Daniel Brosed Giral. Sin marketing genérico, sin humo: protocolos accionables.
        </p>
      </div>

      <div class="resources-featured-stack">
        <article class="resource-featured">
          <div class="resource-featured-content">
            <span class="resource-badge">● GUÍA GRATUITA · DESCARGA INMEDIATA</span>
            <h2 class="resource-featured-title">7 errores que destruyen patrimonio cripto.</h2>
            <p class="resource-featured-tagline">y cómo no cometerlos</p>
            <p class="resource-featured-desc">
              16 páginas técnicas con los siete fallos más comunes que destruyen patrimonio digital,
              con datos reales (Mt. Gox, FTX, Howells, QuadrigaCX, Bybit 2025) y el protocolo concreto
              para evitar cada uno. Por el fundador de VaultBit Advisory.
            </p>
            <a class="btn btn-primary btn-lg" href="/recursos/guia-7-errores">
              Acceder a la guía
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
          <div class="resource-featured-mock">
            <PdfMockupCard rotate={2} />
          </div>
        </article>

        <article class="resource-featured">
          <div class="resource-featured-content">
            <span class="resource-badge">● GUÍA GRATUITA · DESCARGA INMEDIATA</span>
            <h2 class="resource-featured-title">Herencia de criptoactivos en España.</h2>
            <p class="resource-featured-tagline">protocolo en 7 fases</p>
            <p class="resource-featured-desc">
              22 páginas técnicas con el protocolo de herencia Bitcoin en 7 fases. Desde el inventario
              inicial hasta la prueba de vida anual, con integración notarial y capa fiscal sucesoria.
              Por el fundador de VaultBit Advisory.
            </p>
            <a class="btn btn-primary btn-lg" href="/recursos/guia-herencia-bitcoin">
              Acceder a la guía
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
          <div class="resource-featured-mock">
            <PdfMockupCard
              rotate={-2}
              meta="PDF · 22 páginas · ~650 KB"
              badge="● GUÍA TÉCNICA"
              titleHtml="Herencia de criptoactivos<br/><strong>en España.</strong>"
              subtitle="protocolo en 7 fases"
            />
          </div>
        </article>
      </div>

      <div class="resources-preview mt-12">
        <article class="resource-card-soon">
          <h3>Fiscalidad cripto España 2026</h3>
          <p>Modelo 721, modelo 100 y trazabilidad técnica auditable.</p>
          <span class="soon-badge">Próximamente</span>
        </article>
        <article class="resource-card-soon">
          <h3>Multifirma para HNWI</h3>
          <p>Multisig 2-de-3 y 3-de-5 para tesorerías significativas.</p>
          <span class="soon-badge">Próximamente</span>
        </article>
      </div>

      <p class="micro-text mt-12 text-center">
        ¿Quieres avisos cuando publiquemos las próximas guías?
        Suscríbete con cualquiera de las guías y entrarás en la lista.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .resources-featured-stack {
    display: flex;
    flex-direction: column;
    gap: 28px;
    max-width: 1080px;
    margin: 0 auto;
  }

  .resource-featured {
    background: linear-gradient(135deg, var(--anthracite-950) 0%, var(--anthracite-900) 100%);
    color: #fff;
    border-radius: var(--radius-xl);
    padding: 36px 28px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
    box-shadow: var(--shadow-xl);
    border: 1px solid rgba(242,118,26,0.25);
  }
  @media (min-width: 768px) {
    .resource-featured { grid-template-columns: 1.4fr 1fr; gap: 48px; padding: 48px 40px; }
  }
  .resource-badge {
    display: inline-block;
    background: rgba(242,118,26,0.12);
    color: var(--brand-orange-400);
    border: 1px solid rgba(242,118,26,0.3);
    padding: 5px 12px;
    border-radius: var(--radius-full);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.2px;
    margin-bottom: 18px;
  }
  .resource-featured-title {
    color: #fff !important;
    font-size: clamp(28px, 4vw, 40px) !important;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -1px;
    margin: 0 0 4px;
  }
  .resource-featured-tagline {
    color: var(--brand-orange-400);
    font-size: 14px;
    margin: 0 0 16px;
    font-style: italic;
  }
  .resource-featured-desc {
    color: var(--anthracite-100);
    font-size: 15px;
    line-height: 1.65;
    margin: 0 0 24px;
  }
  .resource-featured-mock { display: flex; justify-content: center; align-items: center; }

  .resources-preview {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 980px;
    margin: 0 auto;
  }
  @media (min-width: 768px) { .resources-preview { grid-template-columns: repeat(2, 1fr); } }
  .resource-card-soon {
    background: #fff;
    border: 1px dashed rgba(46,55,64,0.25);
    border-radius: var(--radius-md);
    padding: 24px;
    text-align: left;
    position: relative;
  }
  .resource-card-soon h3 {
    font-size: 16px;
    color: var(--anthracite-950);
    margin: 0 0 8px;
  }
  .resource-card-soon p {
    font-size: 14px;
    color: var(--anthracite-400);
    margin: 0 0 16px;
    line-height: 1.55;
  }
  .soon-badge {
    display: inline-block;
    background: rgba(242,118,26,0.1);
    color: var(--brand-orange-500);
    border: 1px solid rgba(242,118,26,0.2);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 600;
  }
</style>
